# ------------------------------------------------------------------
# REQUIRED: Discord Bot Configuration
# ------------------------------------------------------------------

# Your Discord Bot Token (Get it from the Discord Developer Portal)
DISCORD_BOT_TOKEN=

# Role ID for testing purposes (Optional)
# Right-click a role in Discord (with Developer Mode enabled) to copy the ID
ROLE_GAMER_ID=

# ------------------------------------------------------------------
# OPTIONAL: Network Proxy Configuration
# ------------------------------------------------------------------

# Proxy URL (Leave empty if you have a direct internet connection)
# If you are behind a firewall, enter your local proxy address (e.g., http://127.0.0.1:7890)
PROXY_URL=

# ------------------------------------------------------------------
# REQUIRED: Database Configuration
# ------------------------------------------------------------------

# Database connection URL
# Default is set to a local SQLite file
DATABASE_URL=sqlite:///db.sqlite3

# ------------------------------------------------------------------
# REQUIRED: Stripe Payment Configuration
# ------------------------------------------------------------------

# Your Stripe Secret API Key (Starts with 'sk_test_' or 'sk_live_')
STRIPE_API_KEY=

# Stripe API Version (Date string)
# You can find this in your Stripe Dashboard under Developers > API version
# Example: 2023-10-16
STRIPE_API_VERSION=2023-10-16

# Your Stripe Webhook Signing Secret (Starts with 'whsec_')
STRIPE_WEBHOOK_SECRET=